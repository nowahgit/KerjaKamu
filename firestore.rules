rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isTrainer() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'trainer' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'verified'
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || resource.data.trainerId == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bootcamp_courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /days/{dayId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /bootcamp_progress/{userId}/courses/{courseId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /skill_test_questions/{version} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trainer_applications/{applicationId} {
      allow read: if request.auth != null && (request.auth.uid == applicationId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == applicationId;
      allow update: if isAdmin();
    }

    match /trainers/{trainerId} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == trainerId);
    }
    
    match /sessions/{sessionId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.trainerId || 
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.trainerId || 
        isAdmin()
      );
    }

    match /applications/{appId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }
  }
}